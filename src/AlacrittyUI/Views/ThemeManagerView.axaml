<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AlacrittyUI.ViewModels"
             xmlns:models="clr-namespace:AlacrittyUI.Models"
             xmlns:res="clr-namespace:AlacrittyUI.Resources"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="AlacrittyUI.Views.ThemeManagerView"
             x:DataType="vm:ThemeManagerViewModel">

    <DockPanel Margin="16">
        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,16,0,0">
            <!-- Apply / Import / Export -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{x:Static res:Strings.ButtonApply}"
                        Command="{Binding ApplyThemeCommand}"
                        IsEnabled="{Binding SelectedTheme, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <Button Content="{x:Static res:Strings.ButtonImport}"
                        Click="OnImportClick" />
                <Button Content="{x:Static res:Strings.ButtonExport}"
                        Click="OnExportClick" />
                <Button Content="{x:Static res:Strings.ButtonDelete}"
                        Command="{Binding DeleteThemeCommand}"
                        IsEnabled="{Binding SelectedTheme, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>

            <!-- Save as new theme -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Static res:Strings.ThemeNamePrompt}"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding NewThemeName}" Width="200" />
                <Button Content="{x:Static res:Strings.ButtonSaveAsTheme}"
                        Command="{Binding SaveCurrentAsThemeCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- Theme lists -->
        <ScrollViewer>
            <StackPanel Spacing="16">
                <!-- Built-in themes -->
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.ThemeBuiltIn}"
                               FontSize="16" FontWeight="Bold" />
                    <ListBox ItemsSource="{Binding BuiltInThemes}"
                             SelectedItem="{Binding SelectedTheme}"
                             MaxHeight="250">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ThemeInfo">
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="4">
                                    <Border Width="24" Height="24" CornerRadius="4"
                                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                            BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding PreviewBackground, FallbackValue=#181818}" />
                                        </Border.Background>
                                        <TextBlock Text="A" FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding PreviewForeground, FallbackValue=#d8d8d8}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- User themes -->
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.ThemeUser}"
                               FontSize="16" FontWeight="Bold" />
                    <ListBox ItemsSource="{Binding UserThemes}"
                             SelectedItem="{Binding SelectedTheme}"
                             MinHeight="60" MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ThemeInfo">
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="4">
                                    <Border Width="24" Height="24" CornerRadius="4"
                                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                            BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding PreviewBackground, FallbackValue=#181818}" />
                                        </Border.Background>
                                        <TextBlock Text="A" FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding PreviewForeground, FallbackValue=#d8d8d8}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
